# Fornite da DataPizza il giorno dell'evento
DATAPIZZA_API_KEY=inserisci_qui
OPENAI_API_KEY=inserisci_qui

# Opzionale (se usate Cohere reranker)
COHERE_API_KEY=inserisci_qui

# Qdrant locale (default, non toccare)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=hackapizza

# Corpus BM25 persistito (usato da retrieval in processi separati)
BM25_CORPUS_PATH=data/index/bm25_corpus.jsonl

# Embedding: "local" (GPU), "openai" o "mock" (offline test)
EMBEDDING_MODE=local
EMBEDDING_MOCK_DIM=64

# Validator tuning (usati in check_constraint/check_constraints_batch)
VALIDATOR_MIN_CONFIDENCE=0.6
VALIDATOR_TOP_K=4
VALIDATOR_EVIDENCE_LIMIT=8

# Retrieval reranking: "heuristic", "cross_encoder", "none"
RERANK_MODE=heuristic
RERANK_CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Runtime fallback/demo
ENABLE_STRUCTURED_FALLBACK=1
APP_TIMEOUT_SECONDS=25
HYBRID_CACHE_TTL_SECONDS=90
BATCH_CACHE_TTL_SECONDS=120

# Structured trace JSONL
TRACE_ENABLED=1
TRACE_LOG_PATH=data/traces/agent_trace.jsonl
